<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns:grid="sap.ui.layout.cssgrid"
	xmlns:core="sap.ui.core" xmlns="sap.m" controllerName="com.tic-tac-toe.controller.main" displayBlock="true">
	<Page id="page" title="Tic Tac Toe" showNavButton="true" navButtonPress="onNavBack">
		<headerContent>
			<Button text="Leave Game" id="leaveBtn" press="onLeaveGame" type="Reject" />
		</headerContent>
		<content>
			<HBox justifyContent="Center" class="sapUiSmallMarginTop">
				<ObjectStatus text="You ({game>/mySymbol}): {game>/myName}" state="Success"
					class="sapUiSmallMarginEnd" />
				<ObjectStatus text="vs" class="sapUiSmallMarginEnd" />
				<ObjectStatus text="{game>/opponentName} ({game>/opponentSymbol})" state="Error" />
			</HBox>
			<HBox justifyContent="Center" class="sapUiTinyMarginTop">
				<ObjectStatus id="turnIndicator"
					text="{= ${game>/myTurn} ? 'Your turn' : 'Waiting...'}"
					state="{= ${game>/myTurn} ? 'Success' : 'Warning'}" />
			</HBox>
			<FlexBox alignItems="Center" justifyContent="Center" height="100%"
				class="boardContainer">
				<grid:CSSGrid id="board"
					gridTemplateColumns="repeat(3, 120px)"
					gridTemplateRows="repeat(3, 120px)"
					gridGap="0.5rem">
				</grid:CSSGrid>
			</FlexBox>
		</content>
	</Page>
</mvc:View>