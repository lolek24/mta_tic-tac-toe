<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns:grid="sap.ui.layout.cssgrid"
	xmlns:core="sap.ui.core" xmlns:custom="com.tic-tac-toe.custom.ui.containers"
	xmlns="sap.m" controllerName="com.tic-tac-toe.controller.main" displayBlock="true">
	<Page id="page" title="{i18n>gameTitle}" showNavButton="true" navButtonPress=".onNavBack">
		<headerContent>
			<Button text="{i18n>leaveGame}" id="leaveBtn" press=".onLeaveGame" type="Reject" />
		</headerContent>
		<content>
			<HBox justifyContent="Center" class="sapUiSmallMarginTop">
				<ObjectStatus text="{game>/myName} ({game>/mySymbol})" state="Success"
					class="sapUiSmallMarginEnd" />
				<ObjectStatus text="{i18n>vs}" class="sapUiSmallMarginEnd" />
				<ObjectStatus text="{game>/opponentName} ({game>/opponentSymbol})" state="Error" />
			</HBox>
			<HBox justifyContent="Center" class="sapUiTinyMarginTop">
				<ObjectStatus id="turnIndicator"
					text="{= ${game>/myTurn} ? ${i18n>yourTurn} : ${i18n>waiting} }"
					state="{= ${game>/myTurn} ? 'Success' : 'Warning'}" />
			</HBox>
			<FlexBox alignItems="Center" justifyContent="Center" height="100%"
				class="boardContainer">
				<grid:CSSGrid id="board"
					class="tttBoard"
					gridTemplateColumns="repeat(3, 120px)"
					gridTemplateRows="repeat(3, 120px)"
					gridGap="0.5rem"
					items="{game>/cells}">
					<custom:customControl symbol="{game>symbol}" label="{game>label}" press=".onCellPress" />
				</grid:CSSGrid>
			</FlexBox>
		</content>
	</Page>
</mvc:View>